#!/usr/bin/env bash
# Shared defaults for VLM-related services. Override any of these by exporting
# the variable before sourcing this file.
unset CUDA_DEVICE GROUNDING_DINO_PORT BLIP2ITM_PORT SAM_PORT LLava_PORT LLAMA_PORT MLLM_PATH
unset USER_SIMULATOR_PORT

export VLFM_PYTHON=${VLFM_PYTHON:-$(command -v python)}

export MOBILE_SAM_CHECKPOINT=${MOBILE_SAM_CHECKPOINT:-data/mobile_sam.pt}
export GROUNDING_DINO_CONFIG=${GROUNDING_DINO_CONFIG:-GroundingDINO/groundingdino/config/GroundingDINO_SwinT_OGC.py}
export GROUNDING_DINO_WEIGHTS=${GROUNDING_DINO_WEIGHTS:-data/groundingdino_swint_ogc.pth}
export CLASSES_PATH=${CLASSES_PATH:-vlfm/vlm/classes.txt}

export CUDA_DEVICE=${CUDA_DEVICE:-1}
export GROUNDING_DINO_PORT=${GROUNDING_DINO_PORT:-11081}
export BLIP2ITM_PORT=${BLIP2ITM_PORT:-11082}
export SAM_PORT=${SAM_PORT:-11083}

export LLava_PORT=${LLava_PORT:-8000}
export USER_SIMULATOR_PORT=${USER_SIMULATOR_PORT:-8000}
export LLAMA_PORT=${LLAMA_PORT:-10190}

# MLLM_PATH is consumed by legacy launchers (LLaVA-Next, InternVL3, etc.).
# ProCompNav's main pipeline uses the llama.cpp Qwen3-VL-8B-Instruct GGUF
# server resolved from $HF_HOME, so this defaults to a no-op placeholder.
export MLLM_PATH=${MLLM_PATH:-Qwen/Qwen3-VL-8B-Instruct}

# HuggingFace cache. Override on the host (e.g., export HF_HOME=$HOME/.cache/huggingface)
# and the launcher bind-mounts it into the container.
export HF_HOME=${HF_HOME:-$HOME/.cache/huggingface}
